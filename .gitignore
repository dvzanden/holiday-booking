# .gitignore for a .NET 8 Razor Pages project (Visual Studio)

# Build artifacts
bin/
obj/
artifacts/
publish/

# Visual Studio files
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates

# NuGet
packages/
*.nupkg
.nuget/

# Logs and test results
*.log
TestResults/
*.trx

# Node / frontend
node_modules/
npm-debug.log
yarn-debug.log
yarn-error.log

# Database files
*.mdf
*.ldf
*.sqlite
*.db

# Secrets and local configuration
appsettings.Development.json
.env
secrets.json

# OS files
.DS_Store
Thumbs.db

# JetBrains Rider
.idea/
*.sln.iml

# Optional: ignore published or generated client lib folders
wwwroot/lib/

# Keep project and source files (csproj, sln, Pages/, Program.cs etc.) tracked
